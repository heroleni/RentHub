# ============================================================
# Configuración SMTP para envío real de correos (RentHub)
# ============================================================
# Copia este archivo a ".env" y rellena con tus credenciales.
#   cp .env.example .env
#
# El docker-compose lee estas variables automáticamente.
# ------------------------------------------------------------

# Interruptor maestro. Ponlo en "true" para enviar correos reales.
SMTP_ENABLED=true

# ---- OPCIÓN A: Mailtrap (recomendado para demo/examen) -----
# Crea una cuenta gratis en https://mailtrap.io -> Email Testing
# -> Inbox -> SMTP Settings. Los correos NO salen a internet:
# quedan capturados en tu bandeja de Mailtrap (ideal para mostrar).
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=TU_USUARIO_MAILTRAP
SMTP_PASSWORD=TU_PASSWORD_MAILTRAP
SMTP_USE_SSL=false

# ---- OPCIÓN B: Gmail (correos reales a internet) -----------
# Requiere verificación en 2 pasos + una "App Password" de 16
# dígitos (https://myaccount.google.com/apppasswords).
# NO uses tu contraseña normal de Gmail.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tucorreo@gmail.com
# SMTP_PASSWORD=la-app-password-de-16-digitos
# SMTP_USE_SSL=false

# Remitente que verán los destinatarios
SMTP_FROM_EMAIL=no-reply@renthub.local
SMTP_FROM_NAME=RentHub
